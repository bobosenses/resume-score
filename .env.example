# 环境变量模板 — 复制为 .env.local 并填入真实值
# .env.local 不进 git；本文件进 git 供协作参考
#
# 使用：cp .env.example .env.local && vim .env.local
# 启动前：source .env.local

# MySQL（生产用阿里云 RDS，本地可指 localhost）
export MYSQL_HOST='your-rds-host.mysql.rds.aliyuncs.com'
export MYSQL_PORT=3306
export MYSQL_USER='your-username'
export MYSQL_PASSWORD='your-password'
export MYSQL_DATABASE='nexis_ai'
